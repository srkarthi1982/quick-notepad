---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvContainer } from "@ansiversa/components";
---

<AppShell title="Quick Notepad | Ansiversa" description="A premium, distraction-free notes workspace for fast capture and retrieval.">
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-kicker"><span>Ansiversa Mini App · Productivity</span></div>
      <h1 class="av-gradient-text">Capture clarity in seconds.</h1>
      <p>Create, pin, favorite, and archive personal notes in one calm workspace.</p>
      <div class="av-cta-row">
        <AvButton href="/app">Open Quick Notepad</AvButton>
      </div>
    </AvContainer>
  </section>
</AppShell>
